{
  "functions": {
    "source": "functions",
    "runtime": "python311",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.pyc",
      "__pycache__",
      "test_*.py",
      ".pytest_cache",
      ".venv",
      "venv"
    ]
  },
  "hosting": {
    "public": "../pwa/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}